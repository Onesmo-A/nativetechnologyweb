# Public site URL (used for canonical + Open Graph absolute URLs)
NEXT_PUBLIC_SITE_URL=https://nativetechnology.africa

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-PWPVSZ8RB2

# Google Analytics Data API (for footer cards like Online/Today/Month)
# Get GA_PROPERTY_ID from: GA Admin → Property settings → Property ID
GA_PROPERTY_ID="123456789"
# Create a Google Cloud service account + JSON key, then add the email + private key here
GA_CLIENT_EMAIL="ga-reader@your-project.iam.gserviceaccount.com"
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional MongoDB (enables Admin CMS + DB-backed content + visitor counter)
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority"

# Admin login (generate ADMIN_PASSWORD_HASH with bcrypt)
ADMIN_EMAIL="admin@nativetechnology.africa"
ADMIN_PASSWORD_HASH="$2a$10$replace_with_bcrypt_hash"

# JWT secret for admin cookie signing (use long random string)
ADMIN_JWT_SECRET="replace-with-long-random-secret"
